            <cost name="pts" typeId="points" value="20"/>
          </costs>
        </selectionEntry>
        <selectionEntry type="upgrade" import="true" name="Channelling Staff" hidden="false" id="2af7-9672-98f3-1288" sortIndex="2">
          <profiles>
            <profile name="Channelling Staff" typeId="24d7-7f7d-a4d7-c26c" typeName="Arcane Item" hidden="false" id="db1d-c51e-b7f3-f77c">
              <characteristics>
                <characteristic name="Special Rules" typeId="3df8-4ab0-c4bd-e2ad">The bearer rolls one additional dice whenever they attempt to channel power or dispel dice.</characteristic>
              </characteristics>
            </profile>
          </profiles>
          <constraints>
            <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="01fd-f8a2-56fb-f6c2" includeChildSelections="false"/>
            <constraint type="max" value="1" field="selections" scope="roster" shared="true" id="fe9b-34a2-9deb-ecd9" includeChildSelections="true"/>
          </constraints>
          <costs>
            <cost name="pts" typeId="points" value="20"/>
          </costs>
