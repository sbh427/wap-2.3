              <characteristics>
                <characteristic name="Special Rules" typeId="3df8-4ab0-c4bd-e2ad">The bearer can choose one Signature spell as an additional spell from any of the eight Winds of Magic in this book, even if they normally cannot choose that lore.</characteristic>
              </characteristics>
            </profile>
          </profiles>
